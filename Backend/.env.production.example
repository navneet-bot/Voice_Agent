# Production release profile
# Default code profile is live; set this explicitly in Railway for clarity.
PLATFORM_FEATURE_PROFILE=live

# Rollback switch:
# PLATFORM_FEATURE_PROFILE=shadow

# Backend auth is intentionally not enabled by the live profile until every
# frontend call carries a server-verifiable identity token or private API key.
# Keep false unless the deployment has verified backend identity wired end to end.
FEATURE_AUTH_ENFORCE_BACKEND=false

# Provider/runtime configuration placeholders
GROQ_API_KEY=
DEEPGRAM_API_KEY=
STT_PROVIDER=deepgram
STT_FALLBACK_ENABLED=true
STT_FALLBACK_ON_EMPTY=true
TTS_PROVIDER=edge
TTS_FALLBACK_ENABLED=true

# Telephony/CRM placeholders
WEBHOOK_BASE_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
CRM_WEBHOOK_URL=
