# Copy this file to .env.local and fill in your Firebase project values
# Get these from: Firebase Console → Project Settings → Your apps → Web app

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Backend API URL — required for production (your Railway/Render backend URL)
# Example: https://your-app.up.railway.app
NEXT_PUBLIC_API_URL=

# Production UI feature switches. Backend release profile controls API behavior;
# these switches expose the matching frontend surfaces in Vercel builds.
NEXT_PUBLIC_FLOW_VISUALIZATION_ENABLED=true
NEXT_PUBLIC_CAMPAIGN_LIFECYCLE_ENABLED=true
NEXT_PUBLIC_CRM_READINESS_UI_ENABLED=true
NEXT_PUBLIC_SCRAPE_GENERATE_SCRIPT_ENABLED=true
NEXT_PUBLIC_SCRAPE_WORKER_V1_ENABLED=true
NEXT_PUBLIC_SCRAPE_JOB_CANCEL_ENABLED=true
NEXT_PUBLIC_SCRAPE_STALE_RECOVERY_ENABLED=true
NEXT_PUBLIC_SCRAPE_JOB_EVENTS_ENABLED=true
NEXT_PUBLIC_SCRAPE_LIVE_QA_READINESS_ENABLED=true
NEXT_PUBLIC_SCRAPE_GENERATED_DRAFT_QA_ENABLED=true
NEXT_PUBLIC_TELEPHONY_LIVE_QA_READINESS_ENABLED=true
NEXT_PUBLIC_CAMPAIGN_E2E_QA_READINESS_ENABLED=true
NEXT_PUBLIC_TENANT_SECURITY_AUDIT_ENABLED=true
NEXT_PUBLIC_FINAL_CANARY_ROLLBACK_ENABLED=true
NEXT_PUBLIC_DEMO_RUNTIME_QA_READINESS_ENABLED=true
NEXT_PUBLIC_WS_SCOPED_EVENTS_ENABLED=true
NEXT_PUBLIC_MONITOR_AUTH_PROOF_ENABLED=true
